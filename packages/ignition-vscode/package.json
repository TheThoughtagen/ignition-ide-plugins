{
  "name": "ignition-dev-tools",
  "displayName": "Ignition Dev Tools",
  "description": "Full IDE support for Inductive Automation's Ignition SCADA platform — completions, hover docs, diagnostics, go-to-definition, decode/encode, and CodeLens for embedded scripts.",
  "version": "0.1.0",
  "publisher": "whiskeyhouse",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "ignition",
    "scada",
    "inductive-automation",
    "jython",
    "python",
    "industrial-automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheThoughtagen/ignition-dev-tools"
  },
  "icon": "icon.png",
  "activationEvents": [
    "workspaceContains:**/project.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ignition",
        "extensions": [
          ".ignition"
        ],
        "aliases": [
          "Ignition Resource"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ignition",
        "scopeName": "source.ignition",
        "path": "./syntaxes/ignition.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ignition",
          "title": "Ignition",
          "icon": "resources/ignition-icon.svg"
        }
      ]
    },
    "views": {
      "ignition": [
        {
          "id": "ignitionProjectBrowser",
          "name": "Project Browser",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "ignitionComponentTree",
          "name": "Component Tree",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ignitionProjectBrowser",
        "contents": "No Ignition projects found.\n\nOpen a folder containing a project.json file.\n[Open Folder](command:vscode.openFolder)",
        "when": "true"
      },
      {
        "view": "ignitionComponentTree",
        "contents": "Open a Perspective view.json file to see the component tree.\n[Open JSON File](command:workbench.action.quickOpen)",
        "when": "true"
      }
    ],
    "configuration": {
      "title": "Ignition Dev Tools",
      "properties": {
        "ignition.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the ignition-lsp executable. If empty, the extension will search PATH or install into its global storage."
        },
        "ignition.ignitionVersion": {
          "type": "string",
          "default": "8.1",
          "description": "Ignition platform version for API completions.",
          "enum": [
            "8.1",
            "8.0"
          ]
        },
        "ignition.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens 'Edit Script' actions above embedded scripts in JSON files."
        },
        "ignition.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline diagnostics for Python scripts."
        },
        "ignition.autoConvertTabs": {
          "type": "boolean",
          "default": true,
          "description": "Automatically convert space indentation to tabs when opening Python files in Ignition projects."
        },
        "ignition.kindling.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Kindling executable. If empty, auto-detection will be used."
        }
      }
    },
    "commands": [
      {
        "command": "ignition.convertToTabs",
        "title": "Ignition: Convert Indentation to Tabs"
      },
      {
        "command": "ignition.decodeScript",
        "title": "Ignition: Decode Script at Cursor",
        "icon": "$(edit)"
      },
      {
        "command": "ignition.decodeAll",
        "title": "Ignition: Decode All Scripts in File",
        "icon": "$(files)"
      },
      {
        "command": "ignition.listScripts",
        "title": "Ignition: List All Scripts in Workspace",
        "icon": "$(list-unordered)"
      },
      {
        "command": "ignition.showInfo",
        "title": "Ignition: Show Extension Info"
      },
      {
        "command": "ignition.formatJson",
        "title": "Ignition: Format JSON"
      },
      {
        "command": "ignition.debugLsp",
        "title": "Ignition: Debug LSP"
      },
      {
        "command": "ignition.openWithKindling",
        "title": "Ignition: Open with Kindling"
      },
      {
        "command": "ignition.refreshComponentTree",
        "title": "Ignition: Refresh Component Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "ignition.componentTree.decodeScripts",
        "title": "Decode Scripts",
        "icon": "$(edit)"
      },
      {
        "command": "ignition.searchResources",
        "title": "Ignition: Search Resources",
        "icon": "$(search)"
      },
      {
        "command": "ignition.copyQualifiedPath",
        "title": "Ignition: Copy Qualified Script Path"
      },
      {
        "command": "ignition.refreshProjectBrowser",
        "title": "Ignition: Refresh Project Browser",
        "icon": "$(refresh)"
      },
      {
        "command": "ignition.projectBrowser.revealFiles",
        "title": "Reveal Files in Explorer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ignition.openWithKindling",
          "when": "resourceExtname =~ /\\.(gwbk|modl|idb)$/i",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "ignition.decodeScript",
          "when": "resourceLangId == json",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "ignition.refreshProjectBrowser",
          "when": "view == ignitionProjectBrowser",
          "group": "navigation"
        },
        {
          "command": "ignition.searchResources",
          "when": "view == ignitionProjectBrowser",
          "group": "navigation"
        },
        {
          "command": "ignition.refreshComponentTree",
          "when": "view == ignitionComponentTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ignition.componentTree.decodeScripts",
          "when": "view == ignitionComponentTree && viewItem == componentWithScripts",
          "group": "inline"
        },
        {
          "command": "ignition.projectBrowser.revealFiles",
          "when": "view == ignitionProjectBrowser && viewItem == resourceWithFile",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
